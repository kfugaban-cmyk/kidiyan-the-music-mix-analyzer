# The app works without secrets by using deterministic interpretation.
# Set this only in a server environment (for example, Vercel). Never prefix it with VITE_.
OPENAI_API_KEY=

# Optional server-side model override. The default is the GPT-5.6 alias.
OPENAI_INTERPRETATION_MODEL=gpt-5.6

# Optional local serving or subpath settings.
PORT=5173
BASE_PATH=/
